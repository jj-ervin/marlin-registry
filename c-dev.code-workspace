  "settings": {
    "workbench.colorCustomizations": {
      "activityBar.background": "#223204",
      "titleBar.activeBackground": "#2F4706",
      "titleBar.activeForeground": "#F5FDE5",
      "titleBar.inactiveBackground": "#223204",
      "titleBar.inactiveForeground": "#F5FDE5",
      "statusBar.background": "#223204",
      "statusBar.foreground": "#F5FDE5",
      "statusBar.debuggingBackground": "#223204",
      "statusBar.debuggingForeground": "#F5FDE5",
      "statusBar.noFolderBackground": "#223204",
      "statusBar.noFolderForeground": "#F5FDE5"
    },
    "explorer.sortOrder": "default",
    "search.exclude": {
      "**/node_modules": true,
      "**/.venv": true,
      "**/__pycache__": true,
      "**/lasso_archive/**": true,
      "**/lasso-mvp_archive/**": true,
      "**/_archive/**": true
    },
    "files.exclude": {
      "**/.pytest_cache": true,
      "**/__pycache__": true
    }
  },

  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "git: status all projects",
        "type": "shell",
        "command": ".\\dev-status.ps1",
        "options": { "shell": { "executable": "pwsh", "args": ["-Command"] } },
        "group": "none",
        "presentation": { "reveal": "always", "panel": "shared" },
        "problemMatcher": []
      },
      {
        "label": "git: fetch all projects",
        "type": "shell",
        "command": "$items = Select-String -Path .\\projects.yaml -Pattern '^\\s+path:\\s+(.+)$' | ForEach-Object { $_.Matches[0].Groups[1].Value.Trim().Trim('\"').Trim(\"'\") } | Where-Object { $_ -and $_ -ne '~' }; foreach ($path in $items) { if (Test-Path (Join-Path $path '.git')) { Write-Host \"`n=== $path ===\" -ForegroundColor Cyan; git -C $path fetch --prune 2>&1 } }",
        "options": { "shell": { "executable": "pwsh", "args": ["-Command"] } },
        "group": "none",
        "presentation": { "reveal": "always", "panel": "shared" },
        "problemMatcher": []
      },
      {
        "label": "git: log recent (all projects)",
        "type": "shell",
        "command": "$items = Select-String -Path .\\projects.yaml -Pattern '^\\s+path:\\s+(.+)$' | ForEach-Object { $_.Matches[0].Groups[1].Value.Trim().Trim('\"').Trim(\"'\") } | Where-Object { $_ -and $_ -ne '~' }; foreach ($path in $items) { if (Test-Path (Join-Path $path '.git')) { $log = git -C $path log --oneline -3 2>$null; if ($log) { Write-Host \"`n=== $path ===\" -ForegroundColor Cyan; $log } } }",
        "options": { "shell": { "executable": "pwsh", "args": ["-Command"] } },
        "group": "none",
        "presentation": { "reveal": "always", "panel": "shared" },
        "problemMatcher": []
      }
    ]
  },

  "extensions": {
